{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@app/pages/*": ["./src/app/pages/*"],
      "@app/env/*": ["./src/environments/*"],
      "@app/layouts/*": ["./src/app/layouts/*"],
      "@app/core/*": ["./src/app/core/*"],
      "@app/components/*": ["./src/app/components/*"],
      "@spartan-ng/helm/button": ["./src/components/ui/button/src/index.ts"],
      "@spartan-ng/helm/utils": ["./src/components/ui/utils/src/index.ts"],
      "@spartan-ng/helm/card": ["./src/components/ui/card/src/index.ts"],
      "@spartan-ng/helm/input": ["./src/components/ui/input/src/index.ts"],
      "@spartan-ng/helm/alert": ["./src/components/ui/alert/src/index.ts"],
      "@spartan-ng/helm/icon": ["./src/components/ui/icon/src/index.ts"],
      "@spartan-ng/helm/dialog": ["./src/components/ui/dialog/src/index.ts"],
      "@spartan-ng/helm/label": ["./src/components/ui/label/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./src/components/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/select": ["./src/components/ui/select/src/index.ts"],
      "@spartan-ng/helm/separator": ["./src/components/ui/separator/src/index.ts"],
      "@spartan-ng/helm/sidebar": ["./src/components/ui/sidebar/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./src/components/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./src/components/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./src/components/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/switch": ["./src/components/ui/switch/src/index.ts"],
      "@spartan-ng/helm/table": ["./src/components/ui/table/src/index.ts"],
      "@spartan-ng/helm/accordion": ["./src/components/ui/accordion/src/index.ts"],
      "@spartan-ng/helm/progress": ["./src/components/ui/progress/src/index.ts"],
      "@spartan-ng/helm/checkbox": ["./src/components/ui/checkbox/src/index.ts"],
      "@spartan-ng/helm/navigation-menu": ["./src/components/ui/navigation-menu/src/index.ts"],
      "@spartan-ng/helm/menubar": ["./src/components/ui/menubar/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["./src/components/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/badge": ["./src/components/ui/badge/src/index.ts"],
      "@spartan-ng/helm/date-picker": ["./src/components/ui/date-picker/src/index.ts"],
      "@spartan-ng/helm/calendar": ["./src/components/ui/calendar/src/index.ts"],
      "@spartan-ng/helm/popover": ["./src/components/ui/popover/src/index.ts"],
      "@spartan-ng/helm/tabs": ["./src/components/ui/tabs/src/index.ts"],
      "@spartan-ng/helm/radio-group": ["./src/components/ui/radio-group/src/index.ts"],
      "@spartan-ng/helm/typography": ["./src/components/ui/typography/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
